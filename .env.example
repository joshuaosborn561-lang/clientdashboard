# Database (SQLite for local dev, use Postgres URL for Vercel)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google Ads OAuth (shared across all clients - you manage one OAuth app)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# NOTE: SmartLead and HeyReach API keys are stored per-client in the database.
# Google Ads Customer IDs are also stored per-client.
# Configure these via the Admin panel at /admin/clients
